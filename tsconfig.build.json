{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.stories.*", "src/**/*.test.*"]
}
